# ============================================
# Copier ce fichier en .env.local et remplir
# ============================================

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@db.project-ref.supabase.co:5432/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# JWT Secret (pour tokens sécurisés)
JWT_SECRET=your-random-secret-key-change-in-production
